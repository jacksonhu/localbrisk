{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "LocalBrisk",
  "version": "0.1.0",
  "identifier": "com.localbrisk.app",
  "build": {
    "beforeDevCommand": "cd frontend && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "cd frontend && npm run build",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "LocalBrisk - 本地化全能 AI 智能体工作站",
        "width": 1400,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true,
        "visible": true,
        "useHttpsScheme": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/localbrisk-backend"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "frameworks": [],
      "entitlements": null,
      "providerShortName": null,
      "signingIdentity": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      },
      "deb": {
        "depends": []
      },
      "rpm": {
        "depends": []
      }
    },
    "category": "DeveloperTool",
    "shortDescription": "本地化全能 AI 智能体工作站",
    "longDescription": "LocalBrisk 是一款主打本地安全与极速体验的桌面 AI 助手，通过 Catalog-Schema-Asset 三层架构组织本地数据、知识和智能体。",
    "copyright": "Copyright © 2024 LocalBrisk Team"
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
